# ── Email sending — Gmail SMTP (welcome email) ────────────────────
# 1. Enable 2-Step Verification on the Google account.
# 2. Create an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# Optional: where "new signup" notifications go (defaults to GMAIL_USER).
GMAIL_NOTIFY=you@gmail.com

# ── Contact list — Resend Audience (stores each signup) ───────────
# API key: https://resend.com/api-keys · Audience: https://resend.com/audiences
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# Base number shown as the waitlist queue position (marketing anchor).
WAITLIST_BASE_POSITION=4201
