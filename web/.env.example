# ── Resend (waitlist storage + welcome email) ─────────────────────
# Create a key at https://resend.com/api-keys
RESEND_API_KEY=

# Audience to store signups as contacts: https://resend.com/audiences
RESEND_AUDIENCE_ID=

# Verified sender. Defaults to Resend's shared onboarding@resend.dev for testing.
# For production, verify your domain and use e.g. "Praxis AI <hello@praxis.ai>".
RESEND_FROM=Praxis AI <onboarding@resend.dev>

# Base number shown as the waitlist queue position (marketing anchor).
WAITLIST_BASE_POSITION=4201
