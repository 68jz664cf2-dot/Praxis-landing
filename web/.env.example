# The welcome email is sent by whichever sender is configured:
# Gmail SMTP if the GMAIL_* vars are set, otherwise Resend.
#
# NOTE: many serverless hosts (incl. Vercel) block/throttle outbound SMTP, so
# Gmail may be unreliable in production. Sending via Resend from a domain you
# verify (e.g. praxisio.io) uses HTTP and is reliable everywhere.

# ── Option A: Gmail SMTP ──────────────────────────────────────────
# 1. Enable 2-Step Verification on the Google account.
# 2. Create an App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Optional: where "new signup" notifications go (defaults to GMAIL_USER).
GMAIL_NOTIFY=

# ── Option B: Resend (also stores the contact list) ───────────────
# API key: https://resend.com/api-keys
RESEND_API_KEY=
# Audience to store each signup as a contact: https://resend.com/audiences
RESEND_AUDIENCE_ID=
# Verified-domain sender, e.g. "Praxis AI <customer@praxisio.io>".
# Leave BLANK to run capture-only: signups are stored in the Audience but no
# welcome email is sent. Set it (with a verified domain) to turn sending on.
RESEND_FROM=

# Base number shown as the waitlist queue position (marketing anchor).
WAITLIST_BASE_POSITION=4201
