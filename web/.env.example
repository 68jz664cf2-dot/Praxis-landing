# ── Storage: Google Sheet (source of truth for every registration) ─
# Each signup (name, email, country, age, source, timestamp) is appended as a
# row via a Google Apps Script web app bound to your Sheet. The queue position
# shown to the user = WAITLIST_BASE_POSITION + total signups (a real, growing #).
# Deploy the Apps Script as a web app ("Anyone" access) and paste its URL here.
SHEETS_WEBHOOK_URL=

# ── Welcome email sender ──────────────────────────────────────────
# Sent on registration by whichever is configured: Gmail SMTP if GMAIL_* is set,
# otherwise Resend. NOTE: serverless hosts (incl. Vercel) often block SMTP, so
# Resend from a verified domain (praxisio.io) is the reliable path.

# Resend (recommended for serverless): https://resend.com/api-keys
RESEND_API_KEY=
# Verified-domain sender, e.g. "Praxis AI <customer@praxisio.io>".
# Leave BLANK to capture-only (store signups, no welcome email yet).
RESEND_FROM=

# Gmail SMTP alternative (App Password: https://myaccount.google.com/apppasswords)
GMAIL_USER=
GMAIL_APP_PASSWORD=
GMAIL_NOTIFY=

# Base number the growing queue position counts up from.
WAITLIST_BASE_POSITION=4201
